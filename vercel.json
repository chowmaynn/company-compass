{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.ts": {
      "runtime": "@vercel/node@5.6.22"
    }
  },
  "rewrites": [
    { "source": "/api/kit/:path(.*)", "destination": "/api/kit?__proxy_path=/:path" },
    { "source": "/api/notion/:path(.*)", "destination": "/api/notion?__proxy_path=/:path" },
    { "source": "/api/calendly/:path(.*)", "destination": "/api/calendly?__proxy_path=/:path" },
    { "source": "/api/close/:path(.*)", "destination": "/api/close?__proxy_path=/:path" },
    { "source": "/api/circle/:path(.*)", "destination": "/api/circle?__proxy_path=/:path" },
    { "source": "/api/airtable/:path(.*)", "destination": "/api/airtable?__proxy_path=/:path" },
    { "source": "/api/tally/:path(.*)", "destination": "/api/tally?__proxy_path=/:path" },
    { "source": "/api/intercom/:path(.*)", "destination": "/api/intercom?__proxy_path=/:path" },
    { "source": "/api/stripe/:path(.*)", "destination": "/api/stripe?__proxy_path=/:path" },
    { "source": "/api/supabase/:path(.*)", "destination": "/api/supabase?__proxy_path=/:path" },
    { "source": "/api/skool-supabase/:path(.*)", "destination": "/api/skool-supabase?__proxy_path=/:path" },
    { "source": "/api/ga4/:path(.*)", "destination": "/api/ga4?__proxy_path=/:path" },
    { "source": "/api/bamboohr/:path(.*)", "destination": "/api/bamboohr?__proxy_path=/:path" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
